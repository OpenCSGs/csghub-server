{
  "engine_name": "sglang-qwen3-guard-stream",
  "container_port": 8000,
  "enabled": 1,
  "model_format": "safetensors",
  "engine_images": [
    {
      "compute_type": "gpu",
      "image": "opencsghq/sglang:0.5.3rc0-qwen3-guard-stream",
      "driver_version": "12.8.1",
      "engine_version": "v0.5.3rc0",
      "extra_archs": [
        "Qwen3ForGuardModel"
      ]
    }
  ],
  "engine_args": [
    {
      "name": "context-length",
      "value": "8192",
      "format": "--context-length %s"
    },
    {
      "name": "tensor-parallel-size",
      "value": "1",
      "format": "--tensor-parallel-size %s"
    },
    {
      "name": "mem-fraction-static",
      "value": "0.6",
      "format": "--mem-fraction-static %s"
    },
    {
      "name": "chunked-prefill-size",
      "value": "131072",
      "format": "--chunked-prefill-size %s"
    },
    {
      "name": "page-size",
      "value": "1",
      "format": "--page-size %s"
    }
  ],
  "supported_archs": [
    "Qwen3ForGuardModel"
  ]
}
