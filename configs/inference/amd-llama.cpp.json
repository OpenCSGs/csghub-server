{
  "engine_name": "amd-llama.cpp",
  "enabled": 1,
  "model_format": "gguf",
  "container_port": 8000,
  "description": "llama.cpp OpenAI-compatible GGUF text generation service for ROCm",
  "engine_images": [
    {
      "compute_type": "gpu",
      "image": "opencsghq/llama.cpp-rocm:rocm7.2.2-b9787",
      "driver_version": "7.2.2",
      "engine_version": "b9787"
    }
  ],
  "engine_args": [
    { "name": "ctx-size", "value": "8192", "format": "-c %s" },
    { "name": "parallel", "value": "1", "format": "-np %s" },
    { "name": "batch-size", "value": "2048", "format": "-b %s" },
    { "name": "predict", "value": "-1", "format": "-n %s" },
    { "name": "threads", "value": "-1", "format": "-t %s" },
    { "name": "gpu-layers", "value": "-1", "format": "-ngl %s" },
    { "name": "custom-options", "value": "", "format": "%s" }
  ],
