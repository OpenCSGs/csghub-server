# Serving image for iFLYTEK AudioFly (latent-diffusion text-to-audio model).
# The model repository ships its own inference code (ldm package); this image
# provides the pinned python runtime plus an OpenAI-compatible speech API
# server (see audiofly/server.py). GPU only.
FROM pytorch/pytorch:2.3.1-cuda12.1-cudnn8-runtime

RUN apt-get update && \
    apt-get install -y dumb-init curl && apt-get clean && rm -rf /var/lib/apt/lists/*

# Dependency versions follow the requirements.txt in the AudioFly model repo
# (torch/torchaudio/torchvision come from the base image).
RUN pip install --index-url https://mirrors.aliyun.com/pypi/simple --no-cache-dir \
    transformers==4.30.2 \
    pytorch_lightning==2.3.0 \
    xformers==0.0.27 \
    torchaudio==2.3.1 \
    torchvision==0.18.1 \
    matplotlib \
    scipy \
    jsonlines \
    einops \
    diffusers \
    soundfile \
    fairscale \
    timm \
    positional_encodings \
    fastapi \
    "uvicorn[standard]" \
    csghub-sdk==0.7.10

COPY ./audiofly/ /etc/csghub/
RUN chmod +x /etc/csghub/*.sh

WORKDIR /workspace/
ENV HF_HUB_ENABLE_HF_TRANSFER=0
ENV PORT=8000
EXPOSE 8000
ENTRYPOINT [ "/usr/bin/dumb-init", "--" ]
CMD ["/etc/csghub/serve.sh"]
